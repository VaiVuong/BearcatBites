@{
    ViewData["Title"] = "About Us";
}
<div class="hero-section text-center my-4">
    <h1 class="display-4 fw-bold">About Us</h1>
    <p class="lead mt-3">
        We're a small team of Cincinnati locals with a shared love for great food
        and the communities that create it — dedicated to the Queen City!
    </p>
</div>
<div class="row mt-5 text-center">
    <div class="col-md-4 mb-4">
        <h4 style="color: var(--pp-green);">Our Mission</h4>
        <p>
            To celebrate the diverse culinary traditions found across Cincinnati's
            neighborhoods and connect food lovers with hidden gems they might
            otherwise miss.
        </p>
    </div>
    <div class="col-md-4 mb-4">
        <h4 style="color: var(--pp-green);">What We Cover</h4>
        <p>
            From bowls of Vietnamese Pho and Indian Panipuri, to mugs of Coffee and cups of Boba.
            We explore everything Cincinnati has to offer to eat!
        </p>
    </div>
    <div class="col-md-4 mb-4">
        <h4 style="color: var(--pp-green);">Why Cincinnati?</h4>
        <p>
            Cincinnati is home to an incredible mix of cultures, and its food
            scene reflects that beautifully. We're here to explore every flavor
            the Queen City has to offer.
        </p>
    </div>
</div>
<hr class="my-5" />
<div class="text-center mb-4">
    <h2 class="fw-bold">Meet the Team</h2>
    <p class="text-muted">The Bearcats behind BearcatBites</p>
</div>
<div class="row justify-content-center text-center mb-5">
    <div class="col-md-4 mb-4">
        <div class="card border-0 shadow-sm h-100 p-4">
            <div class="mb-3" style="font-size: 3rem;">🐾</div>
            <h4 class="fw-bold">Pranish Adhikari</h4>
            <p class="text-muted mb-1"><strong>Major:</strong> Software Development</p>
            <p class="text-muted mb-1"><strong>Hobbies:</strong> Boxing, Hiking &amp; Bike Riding</p>
            <p class="mt-2">A Cincinnati foodie who loves exploring the city's diverse restaurant scene — one bite at a time!</p>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card border-0 shadow-sm h-100 p-4">
            <div class="mb-3" style="font-size: 3rem;">🐾</div>
            <h4 class="fw-bold">Chris Vu</h4>
            <p class="text-muted mb-1"><strong>Major:</strong> Information Technology</p>
            <p class="text-muted mb-1"><strong>Hobbies:</strong> Watching Anime &amp; Going Outside</p>
            <p class="mt-2">A Cincinnati explorer who loves discovering new food spots between anime episodes and outdoor adventures!</p>
        </div>
    </div>
</div>
